{
  "name": "mimir-scan",
  "version": "0.1.0",
  "description": "MCP security scanner for AI coding agents — integrates Semgrep, Trivy, Gitleaks, and prompt injection detection",
  "author": {
    "name": "Amit Vishwakarma"
  },
  "homepage": "https://github.com/amitvishw/mimir-scan#readme",
  "bugs": {
    "url": "https://github.com/amitvishw/mimir-scan/issues"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitvishw/mimir-scan.git"
  },
  "keywords": [
    "mimir",
    "mcp",
    "security",
    "scanner",
    "mimir",
    "sast",
    "sca",
    "semgrep",
    "trivy",
    "gitleaks",
    "vulnerability",
    "prompt-injection",
    "claude",
    "copilot",
    "cursor",
    "ai-security"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:e2e": "./test-e2e.sh",
    "test:e2e:docker": "./test-e2e.sh --docker",
    "lint": "eslint src/ && prettier --check src/",
    "lint:fix": "eslint src/ --fix && prettier --write src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "bin": {
    "mimir-scan": "src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "^1.3.11",
    "@types/eslint__js": "9.14.0",
    "eslint": "10.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript-eslint": "8.57.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.28.0",
    "zod": "4.3.6"
  }
}
